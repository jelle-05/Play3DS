# Play3DS — environment variables
#
# Kopieer deze waarden naar de Vercel project settings (Settings → Environment
# Variables) en/of een lokale .env.local. Zet GEEN echte waarden in de repo.
#
# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alleen server-side gebruik (NOOIT NEXT_PUBLIC_). Voor admin-/importscripts.
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics (optioneel) — measurement id, bv. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# IGDB-catalogus (Fase 3.4) — Twitch developer-app, server-only (NOOIT NEXT_PUBLIC_).
# Aanmaken via https://dev.twitch.tv/console/apps — zie SETUP.md §8.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
